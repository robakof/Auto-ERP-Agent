# Konfiguracja połączenia z SQL Server (wyłącznie SQL authentication)
SQL_SERVER=
SQL_DATABASE=
SQL_USERNAME=
SQL_PASSWORD=

# Ścieżka do pliku XLSM z dokumentacją ERP
# Wymagana tylko przy przebudowie indeksu: python tools/build_index.py
# Pozostali użytkownicy nie muszą jej ustawiać (docs.db jest w repozytorium)
XLSM_PATH=

# Bot — konto SQL (serwer i baza jak wyżej, inne konto: CEIM_AIBI z dostępem tylko do AIBI.*)
BOT_SQL_USERNAME=CEIM_AIBI
BOT_SQL_PASSWORD=

# Bot — Claude API
ANTHROPIC_API_KEY=

# Bot — modele Claude (konfigurowalne bez zmiany kodu)
BOT_MODEL_GENERATE=claude-sonnet-4-6
BOT_MODEL_FORMAT=claude-haiku-4-5-20251001

# Bot — Telegram
TELEGRAM_BOT_TOKEN=

# JAS API — instancja testowa
JAS_API_URL=
JAS_AUTH_URL=
JAS_CLIENT_ID=
JAS_CLIENT_SECRET=
JAS_USERNAME=
JAS_PASSWORD=
JAS_SCOPE=extranet_modules_access

# JAS — adres nadawcy (loading place)
JAS_GOODS_NAME=
JAS_LOADING_NAME=
JAS_LOADING_STREET=
JAS_LOADING_HOUSE_NO=
JAS_LOADING_CITY=
JAS_LOADING_ZIP=
JAS_LOADING_COUNTRY=PL

# KSeF 2.0 — integracja z Krajowym Systemem e-Faktur
# KSEF_ENV: demo | test | prod (demo = api-demo.ksef.mf.gov.pl/v2)
KSEF_ENV=demo
KSEF_BASE_URL=
KSEF_TOKEN=
KSEF_NIP=

# KSeF Raporty — SMTP
KSEF_SMTP_HOST=
KSEF_SMTP_PORT=465
KSEF_SMTP_USER=
KSEF_SMTP_PASS=
KSEF_SMTP_SSL=true
KSEF_REPORT_FROM=
KSEF_REPORT_TO=
KSEF_REPORT_SUBJECT_PREFIX=[KSeF]

# KSeF Daemon
KSEF_DAEMON_INTERVAL=900
KSEF_DAEMON_TICK_TIMEOUT=300
KSEF_DAEMON_RATE_LIMIT=10
KSEF_DAEMON_ERROR_THRESHOLD=3

# KSeF Watchdog
KSEF_WATCHDOG_MAX_RESTARTS=5
KSEF_WATCHDOG_HEARTBEAT_STALE=1200
