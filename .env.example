# Konfiguracja połączenia z SQL Server
SQL_SERVER=
SQL_DATABASE=
SQL_USERNAME=
SQL_PASSWORD=
# Alternatywnie: Windows Authentication (zostaw puste SQL_USERNAME i SQL_PASSWORD)
SQL_TRUSTED_CONNECTION=yes

# Ścieżki lokalne
SOLUTIONS_PATH=./solutions
ERP_DOCS_PATH=./erp_docs
LOGS_PATH=./logs/sessions

# Konfiguracja agenta
MAX_ITERATIONS=5
