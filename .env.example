# Konfiguracja połączenia z SQL Server (wyłącznie SQL authentication)
SQL_SERVER=
SQL_DATABASE=
SQL_USERNAME=
SQL_PASSWORD=

# Ścieżki lokalne
SOLUTIONS_PATH=./solutions
ERP_DOCS_PATH=./erp_docs
