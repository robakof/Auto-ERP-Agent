# Środowisko
.env

# Generowane
logs/
__pycache__/
*.pyc

# Pliki tymczasowe SQLite (WAL mode)
*.db-wal
*.db-shm

# Dane źródłowe dokumentacji (duże pliki, nie kod)
erp_docs/raw/

# Pliki tymczasowe agentów
tmp/

# Widoki generowane przez render.py
/views/

# Eksporty SQL generowane przez sql_query.py --export
*_export.xlsx

# Pliki tymczasowe Excel (lock files)
~$*

# Pliki tymczasowe
*.tmp

# Narzędziowe
.claude/memory/
.claude/settings.json
.claude/settings.local.json
bot/.claude/settings.local.json
Prompt.md

# Baza danych (lokalna dla każdej maszyny, synchronizacja w przyszłości)
mrowisko.db
jas.db

# KSeF runtime data (DB, logs, heartbeat) — per-environment, not code
ksef_api/*/data/*
!ksef_api/*/data/.gitkeep

# KSeF generated output (XML, UPO) — per-environment
ksef_api/*/output/*
!ksef_api/*/output/.gitkeep
!ksef_api/*/output/upo/
ksef_api/*/output/upo/*
!ksef_api/*/output/upo/.gitkeep

# Baza danych indeksu dokumentacji (regenerowalna)
docs.db

# Konfiguracje Obsidian (lokalne per użytkownik)
**/.obsidian/

# Pliki z danymi dostępowymi (credentials)
**/API JAS.txt
**/Hasło do raporty.txt
**/mail raporty dane smtp.png

# Błędne pliki systemowe
nul

# Binaria i dokumentacja Comarch API (1.8GB, nie do gita)
API Comarch/

# Output generowany przez narzędzia
output/

# Wzory plików (zawierają klucze, certyfikaty, tokeny)
documents/Wzory plików/
