# Środowisko
.env

# Generowane
logs/
__pycache__/
*.pyc

# Pliki tymczasowe SQLite (WAL mode)
*.db-wal
*.db-shm

# Lokalna baza danych mrowiska (nie wersjonowana)
mrowisko.db

# Dane źródłowe dokumentacji (duże pliki, nie kod)
erp_docs/raw/

# Pliki tymczasowe agentów
tmp/

# Widoki generowane przez render.py
/views/

# Eksporty SQL generowane przez sql_query.py --export
*_export.xlsx

# Pliki tymczasowe Excel (lock files)
~$*

# Pliki tymczasowe
*.tmp

# Narzędziowe
.claude/
Prompt.md
