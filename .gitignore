/views/

# Eksporty SQL generowane przez sql_query.py --export
*_export.xlsx

# Pliki tymczasowe Excel (lock files)
~$*

# Pliki tymczasowe
*.tmp

# Narzędziowe
.claude/memory/
.claude/settings.json
.claude/settings.local.json
bot/.claude/settings.local.json
Prompt.md

# Baza danych (lokalna dla każdej maszyny, synchronizacja w przyszłości)
