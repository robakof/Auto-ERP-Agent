{
  "views": [
    {
      "name": "AIBI.Rezerwacje",
      "file": "views/Rezerwacje.sql",
      "description": "Rezerwacje towarów z pełnymi danymi towaru, kontrahenta, magazynu, dokumentu źródłowego i statusu. Ilości: zarezerwowana, zrealizowana, na dok. mag., do pokrycia. Daty po konwersji z Clarion. Typy dokumentów źródłowych: 960=Zamówienie(ZS/ZZ), 14345=ZPC, 14346=ZPZ→ZP, 2592=BkRez.",
      "primary_table": "CDN.Rezerwacje",
      "joins": [
        "CDN.TwrKarty",
        "CDN.KntKarty",
        "CDN.Magazyny",
        "CDN.ZamNag",
        "CDN.ProdZasoby",
        "CDN.ProdZlecenia",
        "CDN.Dostawy",
        "CDN.TraNag",
        "CDN.Obiekty",
        "CDN.FrmStruktura",
        "CDN.ProdTechnologiaZasoby"
      ],
      "columns": [
        "Typ_Rezerwacji", "ID_Rezerwacji",
        "Kod_Towaru", "Nazwa_Towaru", "Jm_Towaru",
        "Akronim_Kontrahenta", "Nazwa_Kontrahenta",
        "Typ_Dokumentu_Zrodlowego", "Opis_Dokumentu_Zrodlowego", "Numer_Dokumentu_Zrodlowego", "Pozycja_Na_Dok_Zrodlowym",
        "ID_Magazynu", "Kod_Magazynu",
        "Numer_Dokumentu_Dostawy",
        "Ilosc_Zarezerwowana", "Ilosc_Zrealizowana", "Ilosc_Na_Dok_Magazynowych",
        "Data_Wprowadzenia", "Data_Realizacji", "Data_Waznosci", "Data_Aktywacji",
        "Aktywna",
        "Zrodlo_Rezerwacji", "Opis_Zrodla",
        "Data_Planowanej_Dostawy",
        "ID_Centrum_Praw", "Nazwa_Centrum_Praw",
        "Typ_Rez",
        "Priorytet",
        "Data_Rezerwacji",
        "ID_Zasobu_Technologii", "Nazwa_Zasobu_Technologii",
        "ID_Klasy_Cechy",
        "Ilosc_Do_Pokrycia"
      ],
      "example_questions": [
        "jakie są rezerwacje towaru X",
        "ile sztuk towaru X jest zarezerwowane",
        "rezerwacje dla kontrahenta Y",
        "przeterminowane rezerwacje",
        "rezerwacje z zamówienia ZS-9/09/2025/ZTHK",
        "rezerwacje ze zlecenia produkcji ZP-1/08/23/OTO",
        "co jest zarezerwowane na magazynie X",
        "niezrealizowane rezerwacje",
        "ile zostało do pokrycia z rezerwacji towaru X",
        "rezerwacje powiązane z dostawą"
      ],
      "notes": "Aktywna='Tak' AND Ilosc_Do_Pokrycia>0 — bieżące otwarte. Typ_Rez: 'Rezerwacja'/'Nierezerwacja'. Typ_Rezerwacji (GIDTyp): 'Rezerwacja'/'Rezerwacja u dostawcy'. Zrodlo_Rezerwacji: 5=ZamWew, 6=RecznaWew, 9=ZamZew (najczęstsze), 10=RecznaZew, 16=DokMag. Numer_Dokumentu_Dostawy: NULL gdy brak (format: Skrot-Numer/MM/RR[/Seria]; typy: PZ/FZ/PW). Numer_Dokumentu_Zrodlowego: NULL dla BkRez (typ=2592 — samoreferencja). ID_Klasy_Cechy: 0=brak cechy. Nazwa_Centrum_Praw/Nazwa_Zasobu_Technologii: NULL gdy brak powiązania."
    }
  ,
    {
