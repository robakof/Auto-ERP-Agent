        "ID_Grupy", "Sciezka_Grupy",
        "Data_Rejestracji_VAT", "Data_Ostatniej_Modyfikacji", "EFaktura_VAT_Data_Waznosci",
        "Rodzaj_Kontrahenta", "Dzialalnosc_Gospodarcza",
        "Konto_Ksiegowe_Dostawcy", "Konto_Ksiegowe_Odbiorcy"
