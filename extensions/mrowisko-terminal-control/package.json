{
  "name": "mrowisko-terminal-control",
  "displayName": "Mrowisko Agent Launcher",
  "description": "Spawn i zarzadzanie agentami Claude Code w terminalach VS Code",
  "version": "0.3.0",
  "publisher": "mrowisko",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mrowisko.spawnAgent",
        "title": "Mrowisko: Spawn Agent"
      },
      {
        "command": "mrowisko.listAgents",
        "title": "Mrowisko: List Agents"
      },
      {
        "command": "mrowisko.stopAgent",
        "title": "Mrowisko: Stop Agent"
      },
      {
        "command": "mrowisko.focusAgent",
        "title": "Mrowisko: Focus Agent Role"
      },
      {
        "command": "mrowisko.rotateTab",
        "title": "Mrowisko: Rotate Agent Tab"
      }
    ],
    "keybindings": [
      {
        "command": "mrowisko.rotateTab",
        "key": "ctrl+alt+]",
        "when": "terminalFocus"
      }
    ],
    "configuration": {
      "title": "Mrowisko Agent Launcher",
      "properties": {
        "mrowisko.dbPath": {
          "type": "string",
          "default": "mrowisko.db",
          "description": "Path to mrowisko.db (relative to workspace root or absolute)"
        },
        "mrowisko.defaultPermissionMode": {
          "type": "string",
          "enum": ["default", "acceptEdits", "plan", "bypassPermissions"],
          "default": "default",
          "description": "Default permission mode for spawned agents"
        },
        "mrowisko.trustedPairs": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Trusted invoker>target pairs for auto-approve (e.g. developer>erp_specialist)"
        },
        "mrowisko.pollIntervalMs": {
          "type": "number",
          "default": 5000,
          "description": "Interval (ms) for polling pending invocations"
        },
        "mrowisko.startupDelayMs": {
          "type": "number",
          "default": 4000,
          "description": "Delay (ms) before sending first message to spawned Claude Code"
        },
        "mrowisko.autoPromptTemplate": {
          "type": "string",
          "default": "[TRYB AUTONOMICZNY] Rola: {role}. Task: {task}",
          "description": "System prompt template for spawned agents ({role} and {task} are replaced)"
        },
        "mrowisko.terminalLocation": {
          "type": "string",
          "enum": ["editor", "panel"],
          "default": "editor",
          "description": "Where to open agent terminals"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
