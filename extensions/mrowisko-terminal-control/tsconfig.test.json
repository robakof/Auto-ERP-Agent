{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out-test",
    "lib": ["ES2020"],
    "sourceMap": true,
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["mocha", "node"]
  },
  "include": ["src/db.ts", "src/types.ts", "src/test/**/*.ts"],
  "exclude": ["node_modules"]
}
