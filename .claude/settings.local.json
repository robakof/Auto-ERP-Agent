{
  "permissions": {
    "allow": [
      "Bash(PYTHONIOENCODING=utf-8 python tools/conversation_search.py --list --limit 30)",
      "Bash(PYTHONIOENCODING=utf-8 python tools/conversation_search.py --query \"session_init developer\" --limit 30)",
      "Bash(PYTHONIOENCODING=utf-8 python tools/conversation_search.py --query \"role developer\" --limit 30)",
      "Bash(PYTHONIOENCODING=utf-8 python tools/conversation_search.py --query \"developer\" --limit 30)",
      "Bash(PYTHONIOENCODING=utf-8 python tools/conversation_search.py --session 9664ee6a6fe1)",
      "Bash(PYTHONIOENCODING=utf-8 python tools/conversation_search.py --query \"workflow bug fix narzedzie tool\" --limit 20)",
      "Bash(PYTHONIOENCODING=utf-8 python tools/conversation_search.py --query \"suggestions backlog wdrozenie implement\" --limit 20)",
      "Bash(PYTHONIOENCODING=utf-8 python tools/conversation_search.py --query \"feat fix refactor\" --limit 20)",
      "Bash(sqlite3:*)",
      "Bash(ping -n 4 127.0.0.1)",
      "Bash(ping:*)",
      "Bash(taskkill /F /FI \"WINDOWTITLE eq python bot/main.py\")",
      "Bash(taskkill /F /IM python.exe /FI \"MEMUSAGE gt 1\")",
      "Bash(taskkill:*)",
      "Bash(wmic process:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/hooks/pre_tool_use.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/hooks/on_user_prompt.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/hooks/post_tool_use.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/hooks/on_stop.py"
          }
        ]
      }
    ]
  }
}
