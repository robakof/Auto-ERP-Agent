# Database
DATABASE_URL=postgresql+asyncpg://serce:serce_dev@localhost:5432/serce

# JWT
SECRET_KEY=change-me-to-random-32-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# SMS OTP (SMSAPI.pl)
SMSAPI_TOKEN=
SMSAPI_SENDER=Serce

# Email (Resend.com)
RESEND_API_KEY=
EMAIL_FROM=noreply@serce.pl

# CAPTCHA (hCaptcha)
HCAPTCHA_SECRET=
HCAPTCHA_SITEKEY=

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Business rules (defaults — synced with SystemConfig on first start)
INITIAL_HEART_GRANT=5
HEART_BALANCE_CAP=50
REQUEST_DEFAULT_EXPIRY_DAYS=30
FLAG_ADMIN_ALERT_DAYS=7

# Rate limiting
RATE_LIMIT_LOGIN=10/15minutes
RATE_LIMIT_REGISTER=3/day
RATE_LIMIT_SMS=3/day
RATE_LIMIT_MESSAGES=50/hour
RATE_LIMIT_GIFT=10/day

# Environment
ENV=development
LOG_LEVEL=INFO
